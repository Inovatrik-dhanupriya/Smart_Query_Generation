# =============================================================================
# Smart Query / NL → SQL — environment (project root)
# =============================================================================
# Copy from .env.example if needed. Do not commit this file (see .gitignore).
#
# PostgreSQL below: used to auto-create the Userdetails DB + auth_users (sign-up / sign-in).
# For NL→SQL against *your* data, you still connect from the Streamlit sidebar (session pool).
# =============================================================================

# --- Required: Google Gemini (NL→SQL generation & embeddings) ---
GEMINI_API_KEY=

# --- Optional: model overrides (defaults work if omitted) ---
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_EMBED_MODEL=models/gemini-embedding-001
GEMINI_SQL_MAX_OUTPUT_TOKENS=2048
GEMINI_QUOTA_RETRIES=8
GEMINI_RETRY_DELAY_SECONDS=1.5

# --- Streamlit UI → FastAPI backend (no trailing slash) ---
NL_SQL_API_URL=http://127.0.0.1:8000

# --- Remote SQL API for "Sync from schema file" (optional default; can pass per request) ---
REMOTE_API_URL=
REMOTE_API_TIMEOUT_SEC=60

# --- SQL execution limits (read-only SELECT path) ---
SQL_MAX_QUERY_LENGTH=5000
SQL_PREVIEW_LIMIT=1000
SQL_MAX_PAGE_SIZE=5000
SQL_STATEMENT_TIMEOUT_SEC=60
SQL_CACHE_TTL=60

# --- PostgreSQL (same server you use in pgAdmin; required for sign-up / sign-in) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=
USER_DETAILS_DATABASE_NAME=Userdetails
# Optional: use instead of DB_USER for CREATE DATABASE / DDL only
# DB_ADMIN_USER=
# DB_ADMIN_PASSWORD=
AUTH_DB_USER=
AUTH_DB_PASSWORD=

# --- App session (chat history on disk) ---
# Omit SESSION_STORE_FILE to use <repo>/.session_store.json (see main.py; stable even if you run uvicorn from nl_to_sql/)
SESSION_MAX_TURNS=10
SESSION_MAX_AGE_HOURS=24

# --- NL→SQL behaviour ---
AGENT_TABLE_THRESHOLD=10
LLM_CACHE_MAX=200

# --- FAISS / embeddings cache directory (under project root if relative) ---
FAISS_CACHE_DIR=.faiss_cache

# --- Streamlit row-limit dropdown (comma-separated integers) ---
# UI_ROW_LIMIT_OPTIONS=10,20,25,50,100,250,500,1000
UI_DEFAULT_SYNC_ROW_LIMIT=1000

# --- CORS: comma-separated origins for the FastAPI app (defaults to local Streamlit if unset) ---
# CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# --- Legacy: optional default sync schema name (UI normally supplies this). Leave empty. ---
# DB_SYNC_SCHEMA=
