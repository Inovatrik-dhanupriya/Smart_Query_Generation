# PostgreSQL — Userdetails + auth (sign-in); bootstrap uses these if DB_ADMIN_* unset
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=postgres
USER_DETAILS_DATABASE_NAME=Userdetails
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=Dhanu@10299
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=Dhanu@10299

SESSION_MAX_TURNS=10
SESSION_MAX_AGE_HOURS=24
# SESSION_STORE_FILE=  (optional; default is repo-root .session_store.json in main.py)

# AGENT_TABLE_THRESHOLD=10
